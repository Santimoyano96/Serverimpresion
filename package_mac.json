{
  "name": "cajaos-print-server-mac",
  "version": "1.0.0",
  "description": "Servidor de impresión local para CajaOS — macOS",
  "main": "server_mac.js",
  "scripts": {
    "start": "node server_mac.js",
    "build:x64": "pkg server_mac.js --targets node18-macos-x64 --output dist/cajaos-print-server-x64",
    "build:arm64": "pkg server_mac.js --targets node18-macos-arm64 --output dist/cajaos-print-server-arm64",
    "build": "npm run build:x64 && npm run build:arm64"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "puppeteer-core": "^21.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.5"
  }
}
